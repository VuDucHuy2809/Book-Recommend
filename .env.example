# =============================================
# Fahasa AI Camera System – Environment Config
# =============================================

# App
APP_NAME=FahasaAICamera
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fahasa_ai
REDIS_URL=redis://localhost:6379/0

# Camera Sources (JSON array)
CAMERA_SOURCES=[
  {"id":"cam_001","name":"Cua vao chinh","source":"rtsp://admin:pass@192.168.1.100:554/stream1"},
  {"id":"cam_002","name":"Khu sach thieu nhi","source":"rtsp://admin:pass@192.168.1.101:554/stream1"},
  {"id":"cam_003","name":"Quay thanh toan","source":0}
]

# AI Model Paths
YOLO_MODEL_PATH=weights/yolo11n.pt
FACE_MODEL=deepface
TRACKER=bytetrack

# Thresholds
ANOMALY_CONFIDENCE_THRESHOLD=0.75
QUEUE_ALERT_THRESHOLD=5
ZONE_DWELL_ALERT_SECONDS=300

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fahasa-camera-ai

# Alerts
ALERT_WEBHOOK_URL=https://hooks.slack.com/...
ALERT_EMAIL=security@fahasa.com
